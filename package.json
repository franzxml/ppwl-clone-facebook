{
  "name": "ppwl-clone-facebook",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,blue \"bun run dev:api\" \"bun run dev:web\"",
    "dev:api": "bun --cwd apps/api dev",
    "dev:web": "bun --cwd apps/web dev",
    "build": "bun run build:shared && bun run build:api && bun run build:web",
    "build:api": "bun --cwd apps/api build",
    "build:shared": "bun --cwd packages/shared build",
    "build:web": "bun --cwd apps/web build",
    "typecheck": "bun run typecheck:shared && bun run typecheck:api && bun run typecheck:web",
    "typecheck:api": "bun --cwd apps/api typecheck",
    "typecheck:shared": "bun --cwd packages/shared typecheck",
    "typecheck:web": "bun --cwd apps/web typecheck",
    "lint": "bun --cwd apps/web lint",
    "prisma:generate": "bun --cwd apps/api prisma generate",
    "prisma:migrate": "bun --cwd apps/api prisma migrate dev"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "concurrently": "^9.2.1",
    "typescript": "^6.0.3"
  }
}
